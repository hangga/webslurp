{
  "manifest_version": 3,
  "name": "API Slurp",
  "description": "Slurp, inspect & replay API requests",
  "version": "1.3",
  "permissions": ["storage", "tabs", "activeTab", "debugger"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "devtools_page": "devtools.html",
  "action": {
    "default_title": "API Slurp"
  }
}